[Unit]
Description=Webcam MJPEG stream
After=network.target

[Service]
ExecStart=/usr/local/bin/mjpg_streamer \
    -i "input_uvc.so -d /dev/video0 -r 640x480 -f 15" \
    -o "output_http.so -p 8080 -w /usr/local/share/mjpg-streamer/www -c admin:changeme"
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
