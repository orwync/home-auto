[Unit]
Description=Relay Light Controller
After=network.target

[Service]
ExecStart=/usr/bin/python3 /home/pi/Projects/home-auto/relay-light/main.py
WorkingDirectory=/home/pi/Projects/home-auto/relay-light
Restart=on-failure
User=pi
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
